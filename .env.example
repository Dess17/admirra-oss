# =============================================================================
# CORE
# =============================================================================

# Деплой: prod → публичный домен admirra.ru, dev → admirra.online (если FRONTEND_URL не задан).
# Для локальной разработки не задавайте ADMIRRA_DEPLOY_ENV или задайте FRONTEND_URL=http://localhost:5173
ADMIRRA_DEPLOY_ENV=prod
# Явный хост без схемы (редко нужен; перекрывает соответствие dev/prod)
# ADMIRRA_PUBLIC_HOST=
# URL фронта для писем с бэкенда (перекрывает ADMIRRA_DEPLOY_ENV)
# FRONTEND_URL=https://admirra.ru

# OpenAI / AI Report (GPT)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Для ProxyAPI OpenAI endpoint: https://api.proxyapi.ru/openai/v1
# Для прямого OpenAI оставьте пустым.
OPENAI_BASE_URL=
# Прокси для запросов к OpenAI (формат: http://user:pass@host:port)
AI_PROXY_URL=
DATABASE_URL=postgresql://user:password@localhost/analytics_db
SECRET_KEY=change_me
ENCRYPTION_KEY=change_me

# =============================================================================
# LEAD VALIDATOR (PHONE VALIDATION)
# =============================================================================
FAIL_OPEN_MODE=true
JS_TOKEN_ENABLED=true

# DaData
DADATA_API_KEY=
DADATA_SECRET_KEY=
DADATA_TIMEOUT=5.0
DADATA_CACHE_TTL_SEC=86400
DADATA_RETRY_ATTEMPTS=2
DADATA_RETRY_BACKOFF_SEC=0.5

# Redis
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Привязка чата для отчётов: webhook + ссылка t.me/bot?start=...
# Сгенерируйте случайную строку и укажите её же в setWebhook (secret_token)
TELEGRAM_WEBHOOK_SECRET=
# Опционально: username бота без @ (если пусто — подтянется через getMe)
TELEGRAM_BOT_USERNAME=

# SmartCaptcha (Yandex Cloud)
SMARTCAPTCHA_ENABLED=false
SMARTCAPTCHA_CLIENT_KEY=
SMARTCAPTCHA_SERVER_KEY=

# Отключить проверку CAPTCHA (true/false)
CAPTCHA_ENABLED=false
YANDEX_IAM_TOKEN=
YANDEX_FOLDER_ID=

# UTM validation
UTM_VALIDATION_ENABLED=true
UTM_BLACKLISTED_PLACEMENTS=

# MX check
MX_CHECK_ENABLED=true

# Bitrix24
BITRIX24_WEBHOOK_URL=

# Social check providers
# VK: для users.search нужен ПОЛЬЗОВАТЕЛЬСКИЙ OAuth-токен (не сервисный). См. PHONE_PROJECT_SETTINGS.md
VK_API_TOKEN=
GETCONTACT_API_KEY=
GETCONTACT_API_URL=
# GetContact неофициальное (имя по телефону для поиска в VK): TOKEN и AES_KEY из приложения
GETCONTACT_UNOFFICIAL_TOKEN=
GETCONTACT_UNOFFICIAL_AES_KEY=
NUMBUSTER_API_KEY=
NUMBUSTER_API_URL=

# InfoTrackPeople (ITP): по телефону -> Telegram/VK (через socials[] + fallback v1 полей)
INFOTRACKPEOPLE_API_KEY=
INFOTRACKPEOPLE_API_URL=https://datatech.work/public-api/data/search
# Логировать сырой ответ ITP (может содержать персональные данные)
INFOTRACKPEOPLE_LOG_RAW=false

# Telegram проверка через Telethon (опционально): api_id, api_hash с my.telegram.org, session — путь к .session
TELEGRAM_CHECKER_API_ID=
TELEGRAM_CHECKER_API_HASH=
TELEGRAM_CHECKER_SESSION=

# Spam check providers
SPRAVPORTAL_API_KEY=
KASPERSKY_API_KEY=
CALLFILTER_API_KEY=

# Lead scoring (0-100)
LEAD_SCORE_WEIGHT_MOBILE=20
LEAD_SCORE_WEIGHT_DADATA_QC_GOOD=15
LEAD_SCORE_WEIGHT_TELEGRAM=20
LEAD_SCORE_WEIGHT_WHATSAPP=15
LEAD_SCORE_WEIGHT_VK=15
LEAD_SCORE_WEIGHT_VIBER=10
LEAD_SCORE_WEIGHT_TIKTOK=10
LEAD_SCORE_WEIGHT_GOSUSLUGI=25
LEAD_SCORE_WEIGHT_NAME_MATCH_GOSUSLUGI=10
LEAD_SCORE_TIER_HIGH_MIN=70
LEAD_SCORE_TIER_MEDIUM_MIN=40

# Metrica offline conversions
METRICA_ENABLED=false
METRICA_COUNTER_ID=
METRICA_OAUTH_TOKEN=

# Airtable logging
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=rejected_leads

# Email notifications (SMTP) — используется для OTP/регистрации и как fallback для отчётов
# false — не отправлять письма (регистрация/OTP без SMTP; временно при сети/IPv6/фаерволе)
SMTP_ENABLED=true
# Яндекс: SMTP_HOST=smtp.yandex.ru, SMTP_PORT=465 (SSL) или 587 (TLS)
# Пароль приложения: https://id.yandex.ru/ — Безопасность → Пароли приложений
# Gmail: smtp.gmail.com:587, App Password — https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# UniSender Go — транзакционные email для отчётов (HTML + PDF вложение)
# Если API ключ задан — отчёты идут через UniSender, иначе через SMTP выше
# Ключ: https://go.unisender.ru/ → Настройки → API ключи
UNISENDER_API_KEY=
# Адрес отправителя (должен быть подтверждён в UniSender)
UNISENDER_FROM_EMAIL=reports@admirra.ru
UNISENDER_FROM_NAME=AdMirra
# API URL (go2 для данного аккаунта; go1 = альтернатива)
UNISENDER_API_URL=https://go2.unisender.ru/ru/transactional/api/v1
# Секрет для POST /api/health/smtp-probe — проверка TCP до SMTP извне (не храните в публичном репо на проде)
SMTP_DIAGNOSE_SECRET=
# Куда доставлять письма с формы «Предложить идея» (POST /api/support/idea); в письме будет Reply-To = email из формы
SUPPORT_INBOX_EMAIL=support@admirra.ru
# Двухэтапный вход по OTP на email: true/false
AUTH_LOGIN_OTP_ENABLED=true
# Требовать подтверждение email для входа и для запросов с JWT. false — обход (временно при проблемах с почтой)
AUTH_REQUIRE_EMAIL_VERIFIED=true

# Проверка webhook_secret для телефонии (/api/webhook/phone/{project_id})
# Если false — секрет не проверяется, полезно когда интеграция может передать только URL без заголовков.
PHONE_WEBHOOK_SECRET_CHECK_ENABLED=true

# Alerts / Blacklist thresholds
ALERT_THRESHOLD_PERCENT=50.0
ALERT_LOOKBACK_DAYS=7
ALERT_MIN_LEADS=5
PLACEMENT_BLACKLIST_THRESHOLD=70.0
PLACEMENT_BLACKLIST_MIN_LEADS=10
PLACEMENT_BLACKLIST_TTL_DAYS=21

# =============================================================================
# ADS / INTEGRATIONS
# =============================================================================
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_DIRECT_FINANCE_TOKEN=

VK_CLIENT_ID=
VK_CLIENT_SECRET=
# Вход в сайт через VK ID (id.vk.ru). Если пусто, используется VK_CLIENT_ID.
VK_LOGIN_CLIENT_ID=
# Опционально (для OAuth 2.1 Authorization Code + PKCE на бэкенде не обязателен):
VK_LOGIN_CLIENT_SECRET=
# Scope для входа через VK ID (через пробел), например: email phone
VK_LOGIN_SCOPE=email
# Базовый URL API VK ID:
VK_ID_OAUTH_BASE=https://id.vk.ru
# OAuth scope VK Рекламы (через запятую). Имена — раздел Scopes в доке VK Ads (рекламодатель / агентство / менеджер).
# По умолчанию в коде: read_ads,read_payments,create_ads
# VK_ADS_OAUTH_SCOPE=read_ads,read_payments,create_ads

# Вход через MAX: deep link бота https://max.ru/<botName>?start=<payload> + webhook bot_started.
MAX_BOT_TOKEN=
# Опционально: ник бота без @. Если пусто, backend получит его через GET https://platform-api.max.ru/me.
MAX_BOT_NAME=
# Секрет webhook. Укажите эту же строку при POST /subscriptions; 5-256 символов [A-Za-z0-9_-].
MAX_WEBHOOK_SECRET=
MAX_API_BASE=https://platform-api.max.ru
MAX_LOGIN_TTL_SECONDS=300
MAX_POLL_INTERVAL_MS=2000

# Отдельный MAX-бот для доставки отчётов. Не использовать auth-бот.
MAX_REPORTS_BOT_TOKEN=
MAX_REPORTS_BOT_NAME=
MAX_REPORTS_WEBHOOK_SECRET=

MYTARGET_CLIENT_ID=
MYTARGET_CLIENT_SECRET=
MYTARGET_AUTH_URL=https://target-sandbox.my.com/api/v2/oauth2/authorize
MYTARGET_TOKEN_URL=https://target-sandbox.my.com/api/v2/oauth2/token.json
MYTARGET_API_URL=https://target.my.com/api/v2

# Google Sheets (if used)
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# Integration tester (optional)
YANDEX_TOKEN=
VK_TOKEN=

# =============================================================================
# BILLING / SUBSCRIPTIONS
# =============================================================================
BILLING_ENABLED=false
BILLING_ENV=dev
BILLING_ENFORCE_LIMITS=false
# CSV: user_id/email bypass limits (admins/dev)
BILLING_ADMIN_WHITELIST=
BILLING_TRIAL_DAYS=14
BILLING_AI_PERIOD_DAYS=30

# Tariff: Start (as on LP)
BILLING_PLAN_START_PRICE_RUB=1590
BILLING_PLAN_START_MAX_PROJECTS=1
BILLING_PLAN_START_AI_LIMIT=30

# Tariff: Basic
BILLING_PLAN_BASIC_PRICE_RUB=3990
BILLING_PLAN_BASIC_MAX_PROJECTS=5
BILLING_PLAN_BASIC_AI_LIMIT=100

# Tariff: Standard
BILLING_PLAN_STANDARD_PRICE_RUB=9900
BILLING_PLAN_STANDARD_MAX_PROJECTS=15
BILLING_PLAN_STANDARD_AI_LIMIT=300

# CloudPayments
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
CLOUDPAYMENTS_CURRENCY=RUB
# Optional HMAC secret for webhook signature verification
CLOUDPAYMENTS_WEBHOOK_SECRET=
# Онлайн-чек (CloudKassir через CloudPayments receipt)
# taxationSystem: 0=ОСН, 1=УСН доход, 2=УСН доход-расход, 3=ЕНВД, 4=ЕСН, 5=ПСН
CLOUDPAYMENTS_RECEIPT_TAXATION_SYSTEM=0
# vat: 0, 10, 20 (или другие доступные в вашем ЛК ставки)
CLOUDPAYMENTS_RECEIPT_VAT=0
# method/object — теги 1214/1212, для SaaS обычно object=4 (услуга), method=0 (полный расчет)
CLOUDPAYMENTS_RECEIPT_METHOD=0
CLOUDPAYMENTS_RECEIPT_OBJECT=4

# Сборка: prod → admirra.ru, dev → admirra.online (должно совпадать с ADMIRRA_DEPLOY_ENV на бэкенде)
VITE_ADMIRRA_DEPLOY_ENV=prod
# Явный хост (без https://), перекрывает выбор по dev/prod
# VITE_ADMIRRA_PUBLIC_HOST=

# Локальный vite dev: прокси /api на бэкенд (по умолчанию 127.0.0.1:8001)
# VITE_DEV_API_PROXY=http://127.0.0.1:8001
